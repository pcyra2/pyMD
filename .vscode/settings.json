        "ampereq",
        "bioq",
        "chelpg",
        "compchem",
        "compchemq",
        "cpptraj",
        "defq",
        "forcefield",
        "FORCEFIELDS",
        "frcmod",
        "gres",
        "HETATM",
        "hpclogin",
        "leaprc",
        "loadamberparams",
        "loadmol",
        "loadpdb",
        "nosymm",
        "ntasks",
        "parmchk",
        "phosaa",
        "resid",
        "resname",
        "saveamberparm",
        "savepdb",
        "SBATCH",
        "tleap",
        "trajin",
        "trajout"
    ],
    "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8",
    "editor.formatOnSave": true
  }
}
